# ============================================================
# ProManage - Root .env File (copy this to .env and fill in)
# ============================================================

# --- Supabase Database ---
# Transaction pooler (port 6543) — used by the app at runtime
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session pooler (port 5432) — used for Prisma migrations
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# --- Security ---
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=replace_with_a_very_long_random_secret_at_least_64_chars

# --- URLs ---
# The public IP or domain of your server (no trailing slash)
# Example with IP:    http://123.45.67.89
# Example with domain: https://api.yourdomain.com
FRONTEND_URL=http://YOUR_SERVER_IP:3000
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:5000/api
